# Shared
LIA_ENV=development

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:55432/licitaciones_ia

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
INTERNAL_API_BASE_URL=http://127.0.0.1:8001
INTERNAL_WEB_BASE_URL=http://127.0.0.1:3000

# Ingestion
CONNECTOR_TIMEOUT_SECONDS=30
USER_AGENT=LicitacionesIA-POC/0.1
OCR_PDFTOPPM_TIMEOUT_SECONDS=120
OCR_TESSERACT_TIMEOUT_SECONDS=120

# LLM
LLM_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AUTOMATION_POLL_SECONDS=60

# Email alerts
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ARCA company lookup
ARCA_PADRON_ARCHIVE_URL=https://www.afip.gob.ar/genericos/cInscripcion/archivos/apellidoNombreDenominacion.zip
ARCA_PADRON_CACHE_HOURS=168
ARCA_WS_CONSTANCIA_URL=https://aws.arca.gob.ar/sr-padron/webservices/personaServiceA5
ARCA_WS_TOKEN=
ARCA_WS_SIGN=
ARCA_WS_CUIT_REPRESENTADA=

# WhatsApp alerts
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=mock
WHATSAPP_META_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_API_VERSION=v23.0
WHATSAPP_OUTBOX_PATH=data/outbox/whatsapp_messages.jsonl
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
ALERT_DISPATCH_BATCH_SIZE=50
ALERT_DISPATCH_MAX_ATTEMPTS=5

# Auth
SESSION_SECRET=change-me-in-production
SESSION_COOKIE_NAME=propscrap_session
SESSION_MAX_AGE_SECONDS=1209600
