# Shared
LIA_ENV=development

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:54329/licitaciones_ia

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
INTERNAL_API_BASE_URL=http://127.0.0.1:8001
INTERNAL_WEB_BASE_URL=http://127.0.0.1:3000

# Ingestion
CONNECTOR_TIMEOUT_SECONDS=30
USER_AGENT=LicitacionesIA-POC/0.1

# LLM
LLM_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# WhatsApp alerts
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=mock
WHATSAPP_META_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_API_VERSION=v23.0
WHATSAPP_OUTBOX_PATH=data/outbox/whatsapp_messages.jsonl
ALERT_DISPATCH_BATCH_SIZE=50
ALERT_DISPATCH_MAX_ATTEMPTS=5

# Auth
SESSION_SECRET=change-me-in-production
SESSION_COOKIE_NAME=propscrap_session
SESSION_MAX_AGE_SECONDS=1209600
